//@version=6
strategy("Checklist Reversal Strategy", overlay = true, margin_long = 100, margin_short = 100, initial_capital = 10000, commission_type = strategy.commission.cash_per_contract, commission_value = 2.0, default_qty_type = strategy.fixed, default_qty_value = 1, slippage = 1)

// --- Constants ---
var string G_SESSION = "Session & Timeframe"
var string G_ZONES   = "Zone Configuration"
var string G_RISK    = "Risk Management"
var string G_BACK    = "Backtest Period"
var string G_FVG     = "FVG Filter"

// --- Inputs ---
sessionInput    = input.session("0930-1130:23456", "Trading Window (EST)", group = G_SESSION)
timeZoneInput   = input.string("America/New_York", "Timezone", group = G_SESSION)
htfInput        = input.timeframe("15", "Higher Timeframe", group = G_SESSION)

lookbackInput   = input.int(100, "15m Pivot Lookback", minval = 20, group = G_ZONES)
proximityInput  = input.float(0.1, "Zone Proximity (%)", step = 0.01, group = G_ZONES, tooltip = "Max distance between two pivots to form a zone") / 100

startDate = input.time(timestamp("2024-01-01 00:00"), "Start Date", group = G_BACK)
endDate   = input.time(timestamp("2025-12-31 23:59"), "End Date", group = G_BACK)

rrInput         = input.float(3.0, "Risk:Reward Ratio", step = 0.1, group = G_RISK)
beTriggerInput  = input.float(1.5, "Break-Even Trigger (RR)", step = 0.1, group = G_RISK)
tickBuffer      = input.int(2, "SL Buffer (Ticks)", group = G_RISK)
volSpikeMult    = input.float(1.5, "Volume Spike Multiplier", step = 0.1, group = G_ZONES, tooltip = "Volume must be X times the 20-period average")

useFvgFilter    = input.bool(true, "Require FVG Confirmation", group = G_FVG, tooltip = "Only enter if price is inside an active FVG in the signal direction")
fvgLookback     = input.int(20, "FVG Lookback (bars)", minval = 5, maxval = 100, group = G_FVG)

// --- Colors ---
COLOR_BULL = #089981
COLOR_BEAR = #f23645

// --- Helper Functions ---
is_in_session() =>
    not na(time(timeframe.period, sessionInput, timeZoneInput))

get_body_ratio(o, h, l, c) =>
    body = math.abs(c - o)
    _range = h - l
    _range == 0 ? 0 : body / _range

// --- HTF Logic (15m) ---
[h_pivots, l_pivots] = request.security(syminfo.tickerid, htfInput, [ta.pivothigh(5, 5), ta.pivotlow(5, 5)], lookahead = barmerge.lookahead_off)

var float[] resPivots = array.new_float()
var float[] supPivots = array.new_float()

if not na(h_pivots) and (array.size(resPivots) == 0 or h_pivots != array.get(resPivots, array.size(resPivots)-1))
    array.push(resPivots, h_pivots)
    if array.size(resPivots) > lookbackInput
        array.shift(resPivots)

if not na(l_pivots) and (array.size(supPivots) == 0 or l_pivots != array.get(supPivots, array.size(supPivots)-1))
    array.push(supPivots, l_pivots)
    if array.size(supPivots) > lookbackInput
        array.shift(supPivots)

float activeRes = na
float activeSup = na

if array.size(resPivots) >= 2
    for i = 0 to array.size(resPivots) - 2
        for j = i + 1 to array.size(resPivots) - 1
            p1 = array.get(resPivots, i)
            p2 = array.get(resPivots, j)
            if math.abs(p1 - p2) <= p1 * proximityInput
                activeRes := math.max(p1, p2)
                break

if array.size(supPivots) >= 2
    for i = 0 to array.size(supPivots) - 2
        for j = i + 1 to array.size(supPivots) - 1
            p1 = array.get(supPivots, i)
            p2 = array.get(supPivots, j)
            if math.abs(p1 - p2) <= p1 * proximityInput
                activeSup := math.min(p1, p2)
                break

// --- LTF Logic ---
atr = ta.atr(14)
threeBarRange    = high - low[2]
threeBarBodyAvg  = (get_body_ratio(open, high, low, close) + get_body_ratio(open[1], high[1], low[1], close[1]) + get_body_ratio(open[2], high[2], low[2], close[2])) / 3
avgVol           = ta.sma(volume, 20)
speedCheck       = threeBarBodyAvg > 0.6 and threeBarRange > atr * 1.2 and volume > avgVol * volSpikeMult

m1_swing_high = ta.pivothigh(3, 3)
m1_swing_low  = ta.pivotlow(3, 3)
var float last_m1_high = na
var float last_m1_low  = na
if not na(m1_swing_high)
    last_m1_high := m1_swing_high
if not na(m1_swing_low)
    last_m1_low := m1_swing_low

bodyRatio    = get_body_ratio(open, high, low, close)
is_marubozu  = bodyRatio > 0.8 and (close < open ? (close <= low + (high - low) * 0.25) : (close >= high - (high - low) * 0.25))
is_engulfing = math.abs(close - open) > math.abs(close[1] - open[1]) and (close > open) != (close[1] > open[1])

var bool touchedRes       = false
var bool touchedSup       = false
var int  barsSinceTouchRes = 0
var int  barsSinceTouchSup = 0

if not na(activeRes) and high > activeRes
    touchedRes        := true
    barsSinceTouchRes := 0
else
    barsSinceTouchRes += 1

if not na(activeSup) and low < activeSup
    touchedSup        := true
    barsSinceTouchSup := 0
else
    barsSinceTouchSup += 1

if barsSinceTouchRes > 30
    touchedRes := false
if barsSinceTouchSup > 30
    touchedSup := false

// --- FVG Detection ---
// Bullish FVG: candle[2].high < candle[0].low  →  upward gap / void
// Bearish FVG: candle[2].low  > candle[0].high →  downward gap / void
bullFvgTop    = low
bullFvgBottom = high[2]
isBullFvg     = bullFvgBottom < bullFvgTop

bearFvgBottom = high
bearFvgTop    = low[2]
isBearFvg     = bearFvgBottom < bearFvgTop

var float[] bullFvgTops    = array.new_float()
var float[] bullFvgBottoms = array.new_float()
var float[] bearFvgTops    = array.new_float()
var float[] bearFvgBottoms = array.new_float()

if isBullFvg
    array.push(bullFvgTops,    bullFvgTop)
    array.push(bullFvgBottoms, bullFvgBottom)
    if array.size(bullFvgTops) > fvgLookback
        array.shift(bullFvgTops)
        array.shift(bullFvgBottoms)

if isBearFvg
    array.push(bearFvgTops,    bearFvgTop)
    array.push(bearFvgBottoms, bearFvgBottom)
    if array.size(bearFvgTops) > fvgLookback
        array.shift(bearFvgTops)
        array.shift(bearFvgBottoms)

inBullFvg = false
inBearFvg = false

if array.size(bullFvgTops) > 0
    for i = 0 to array.size(bullFvgTops) - 1
        if close >= array.get(bullFvgBottoms, i) and close <= array.get(bullFvgTops, i)
            inBullFvg := true

if array.size(bearFvgTops) > 0
    for i = 0 to array.size(bearFvgTops) - 1
        if close >= array.get(bearFvgBottoms, i) and close <= array.get(bearFvgTops, i)
            inBearFvg := true

fvgLongOk  = not useFvgFilter or inBullFvg
fvgShortOk = not useFvgFilter or inBearFvg

// --- Trade Conditions ---
inSession   = is_in_session()
inDateRange = time >= startDate and time <= endDate

longCondition  = inDateRange and inSession and touchedSup and close > activeSup and speedCheck and close > last_m1_high and (is_marubozu or is_engulfing) and fvgLongOk
shortCondition = inDateRange and inSession and touchedRes and close < activeRes and speedCheck and close < last_m1_low  and (is_marubozu or is_engulfing) and fvgShortOk

// --- Strategy Management ---
var float entryPrice  = na
var float stopPrice   = na
var float targetPrice = na
var bool  beMoved     = false

if longCondition and strategy.position_size == 0
    entryPrice  := close
    stopPrice   := low - (tickBuffer * syminfo.mintick)
    risk         = entryPrice - stopPrice
    targetPrice := entryPrice + (risk * rrInput)
    beMoved     := false
    strategy.entry("Long", strategy.long, comment = "MSS Long")
    touchedSup  := false

if shortCondition and strategy.position_size == 0
    entryPrice  := close
    stopPrice   := high + (tickBuffer * syminfo.mintick)
    risk         = stopPrice - entryPrice
    targetPrice := entryPrice - (risk * rrInput)
    beMoved     := false
    strategy.entry("Short", strategy.short, comment = "MSS Short")
    touchedRes  := false

// Break-Even Logic
if strategy.position_size > 0
    risk = entryPrice - stopPrice
    if high >= entryPrice + (risk * beTriggerInput) and not beMoved
        stopPrice := entryPrice + syminfo.mintick
        beMoved   := true

if strategy.position_size < 0
    risk = stopPrice - entryPrice
    if low <= entryPrice - (risk * beTriggerInput) and not beMoved
        stopPrice := entryPrice - syminfo.mintick
        beMoved   := true

if strategy.position_size != 0
    strategy.exit("Exit", limit = targetPrice, stop = stopPrice, comment_loss = "SL", comment_profit = "TP")

// --- Visuals ---
plot(activeRes, "HTF Resistance", color.new(COLOR_BEAR, 20), 2, plot.style_linebr)
plot(activeSup, "HTF Support",    color.new(COLOR_BULL, 20), 2, plot.style_linebr)

// BUY / SELL signal arrows
plotshape(longCondition,  "BUY",  shape.labelup,   location.belowbar, COLOR_BULL, size = size.normal, text = "BUY",  textcolor = color.white)
plotshape(shortCondition, "SELL", shape.labeldown,  location.abovebar, COLOR_BEAR, size = size.normal, text = "SELL", textcolor = color.white)

// FVG zone background highlight
bgcolor(inBullFvg ? color.new(COLOR_BULL, 92) : na, title = "In Bull FVG")
bgcolor(inBearFvg ? color.new(COLOR_BEAR, 92) : na, title = "In Bear FVG")

// Debug markers
plotshape(speedCheck,              "Speed Valid",       shape.diamond, location.bottom, color.new(color.yellow, 50), size = size.tiny)
plotshape(touchedRes or touchedSup, "Zone Touch Active", shape.circle,  location.top,    color.new(color.white, 50),  size = size.tiny)

bgcolor(inSession ? color.new(color.blue, 95) : na)

// --- Alerts ---
session_window   = "0930-1600:23456"
in_session_full  = time(timeframe.period, session_window, "America/New_York")
is_session_start = not na(in_session_full) and na(in_session_full[1])
is_session_end   = na(in_session_full) and not na(in_session_full[1])

if is_session_start
    alert("NY Market Open - Trading window active", alert.freq_once_per_bar)
if is_session_end
    alert("NY Market Close - Trading window inactive", alert.freq_once_per_bar)
if (longCondition or shortCondition) and not na(in_session_full)
    alert("Reversal Entry Signal: Checklist Met + FVG Confirmed", alert.freq_once_per_bar)
