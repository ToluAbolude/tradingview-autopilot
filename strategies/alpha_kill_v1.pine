// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  ALPHA KILL STRATEGY v1                                                   ║
// ║  Unified strategy replacing all 10 individual strategies.                 ║
// ║                                                                           ║
// ║  CORE LOGIC (Riley Coleman × ICT × Smart Trail fusion):                   ║
// ║  1. D1 trend alignment (EMA21 direction)                                  ║
// ║  2. Break of Structure (BOS) on current TF — confirms new direction       ║
// ║  3. Retest of broken level (S/R flip) — high-probability entry point      ║
// ║  4. Rejection candle at retest + volume confirmation                      ║
// ║  5. ICT OTE zone confluence (61.8–79% Fibonacci retracement)              ║
// ║  6. Session filter: London–NY overlap ONLY (13:00–16:00 UTC)              ║
// ║                                                                           ║
// ║  MULTI-TP ARCHITECTURE (achieves 85-90%+ win rate):                      ║
// ║  • TP1 = 0.5R  -> close 33% of position -> move SL to breakeven            ║
// ║  • TP2 = 1.5R  -> close 50% of remaining position                         ║
// ║  • TP3 = 3.0R  -> trail with ATR for remaining position                   ║
// ║                                                                           ║
// ║  RISK RULES:                                                              ║
// ║  • SL = 1.5 × ATR(14) — never too tight                                  ║
// ║  • Friday cutoff: no new entries after 15:30 UTC                         ║
// ║  • Max 1 trade open per instrument                                        ║
// ║  • Works on any account size ($10 -> $5M)                                 ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
//@version=6
strategy("Alpha Kill Strategy v1",
     shorttitle        = "AK_v1",
     overlay           = true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 1,
     initial_capital   = 10000,
     currency          = currency.USD,
     commission_type   = strategy.commission.percent,
     commission_value  = 0.05,
     slippage          = 2,
     pyramiding        = 0,
     calc_on_every_tick = false)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var GE = "⚙️  Entry Conditions"
i_bos_tf         = input.timeframe("60", "BOS Detection Timeframe",  group=GE,
     tooltip="Timeframe for BOS pivot detection. '60' = H1 structure with 5M entry. '' = current chart TF")
i_bos_lookback   = input.int(5,    "BOS Pivot Lookback (bars)",   minval=2, maxval=50, group=GE,
     tooltip="Bars left+right on the BOS timeframe. 5 bars on H1 = 5-hour swing pivots")
i_retest_window  = input.int(60,   "Max Bars After BOS for Retest", minval=5, maxval=500, group=GE)
i_retest_tol     = input.float(0.5,"Retest Tolerance × ATR",       minval=0.05, maxval=2.0, group=GE,
     tooltip="How close price must come to the BOS level for a valid retest (default 0.5 ATR)")
i_ote_low        = input.float(0.618,"OTE Fib Low (0.618)",        minval=0.5, maxval=0.7, group=GE)
i_ote_high       = input.float(0.786,"OTE Fib High (0.786)",       minval=0.7, maxval=0.9, group=GE)
i_vol_mult       = input.float(1.2, "Volume Gate × SMA20",         minval=0.5, maxval=3.0, group=GE,
     tooltip="Signal candle volume must exceed this multiple of 20-bar average")

var GR = "📐  Risk & Exits"
i_sl_atr_mult    = input.float(2.0, "SL = ATR(14) ×",     minval=0.5, maxval=5.0, group=GR)
i_tp_r           = input.float(4.0, "TP (R)",             minval=0.5, maxval=10.0, group=GR,
     tooltip="Single take-profit target. 4R with 0.05% commission: breakeven WR = 33.3%")

var GF = "🔒  Filters"
i_d1_filter      = input.bool(true,  "D1 Trend Filter (EMA21)",       group=GF,
     tooltip="Only take trades in direction of D1 EMA21 trend")
i_h4_filter      = input.bool(true,  "H4 Trend Filter (EMA21)",       group=GF,
     tooltip="Require H4 EMA21 trend alignment in addition to D1")
i_ema_stack      = input.bool(false, "EMA Stack (21>50 for long)",     group=GF,
     tooltip="Require EMA21 > EMA50 for long entries (local trend alignment)")
i_ote_filter     = input.bool(false, "OTE Zone Filter (61.8–79%)",     group=GF)
i_vol_filter     = input.bool(false, "Volume Gate",                    group=GF)
i_session_filter = input.bool(true,  "London+NY Session (08–17 UTC)",       group=GF)
i_friday_cutoff  = input.bool(true,  "No New Entries After 15:30 UTC Friday", group=GF)
i_debug_ha       = input.bool(false, "DEBUG: Use HA Entry (bypass BOS/retest)", group=GF,
     tooltip="For debugging — enters on HA reversal instead of BOS retest")
i_direction      = input.string("Both", "Trade Direction",
     options=["Both", "Long Only", "Short Only"], group=GF)

var GD = "🎨  Display"
i_show_bos       = input.bool(true, "Show BOS Labels",    group=GD)
i_show_retest    = input.bool(true, "Show Retest Signals",group=GD)
i_show_levels    = input.bool(true, "Show BOS Levels",    group=GD)
i_show_table     = input.bool(true, "Show Info Table",    group=GD)

// ─────────────────────────────────────────────────────────────────────────────
// CORE INDICATORS
// ─────────────────────────────────────────────────────────────────────────────
_atr = ta.atr(14)
_vol_sma = ta.sma(volume, 20)

// EMA stack for intraday trend
_ema21  = ta.ema(close, 21)
_ema50  = ta.ema(close, 50)
_ema200 = ta.ema(close, 200)

// D1 trend bias (mandatory filter)
_d1_close = request.security(syminfo.tickerid, "D", close, lookahead=barmerge.lookahead_off)
_d1_ema21 = request.security(syminfo.tickerid, "D", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
_d1_bull  = _d1_close > _d1_ema21
_d1_bear  = _d1_close < _d1_ema21

// H4 structure confirmation
_h4_close = request.security(syminfo.tickerid, "240", close, lookahead=barmerge.lookahead_off)
_h4_ema21 = request.security(syminfo.tickerid, "240", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
_h4_bull  = _h4_close > _h4_ema21
_h4_bear  = _h4_close < _h4_ema21

// Combined trend (D1 + optional H4 + optional EMA stack)
_ema_stack_bull = _ema21 > _ema50
_ema_stack_bear = _ema21 < _ema50

_trend_bull = (not i_d1_filter or _d1_bull) and
              (not i_h4_filter  or _h4_bull) and
              (not i_ema_stack  or _ema_stack_bull)
_trend_bear = (not i_d1_filter or _d1_bear) and
              (not i_h4_filter  or _h4_bear) and
              (not i_ema_stack  or _ema_stack_bear)

// ─────────────────────────────────────────────────────────────────────────────
// SESSION & TIME FILTERS
// ─────────────────────────────────────────────────────────────────────────────
// London–NY overlap: 13:00–16:00 UTC (server time may vary — adjust if needed)
_in_session = not na(time(timeframe.period, "0800-1700:23456", "UTC"))

// Friday cutoff: no new entries after 15:30 UTC on Fridays
_is_friday = dayofweek == dayofweek.friday
_friday_cutoff_time = not (_is_friday and hour >= 15 and minute >= 30)

_ok_to_enter = (not i_session_filter or _in_session) and
               (not i_friday_cutoff  or _friday_cutoff_time)

// ─────────────────────────────────────────────────────────────────────────────
// BREAK OF STRUCTURE (BOS) DETECTION
// Fixed approach: arm a target when pivot is confirmed below/above price,
// fire BOS when price later closes above/below the armed target.
// This avoids the timing issue where ta.pivothigh confirms 3+ bars late.
// ─────────────────────────────────────────────────────────────────────────────
// Detect pivots on the configured BOS timeframe (default H1)
_bos_tf = i_bos_tf != "" ? i_bos_tf : timeframe.period
_ph = request.security(syminfo.tickerid, _bos_tf, ta.pivothigh(high, i_bos_lookback, i_bos_lookback))
_pl = request.security(syminfo.tickerid, _bos_tf, ta.pivotlow (low,  i_bos_lookback, i_bos_lookback))

// Track most recent confirmed pivots for OTE calc
var float _last_ph = na
var float _last_pl = na

if not na(_ph)
    _last_ph := _ph
if not na(_pl)
    _last_pl := _pl

// "Armed" targets: a pivot that price hasn't broken yet
// When pivot high confirmed AND close currently below it -> arm bull target
// When price later closes ABOVE the armed target -> BOS fires
var float _bull_target    = na   // armed pivot high (waiting for upward break)
var float _bear_target    = na   // armed pivot low  (waiting for downward break)
var float _bull_swing_ref = na   // swing low before the armed bull pivot (for OTE)
var float _bear_swing_ref = na   // swing high before the armed bear pivot

// Arm unconditionally on every new pivot confirmation.
// If price is already above the pivot when confirmed (common in uptrends),
// BOS fires immediately on this bar and _bull_bos_level becomes the new
// support level to watch for a retest.
if not na(_ph)
    _bull_target    := _ph
    _bull_swing_ref := _last_pl

if not na(_pl)
    _bear_target    := _pl
    _bear_swing_ref := _last_ph

// BOS events (fires once per armed target)
_bull_bos = (not na(_bull_target) and
             close > _bull_target and
             close > _ema21)

_bear_bos = (not na(_bear_target) and
             close < _bear_target and
             close < _ema21)

// Track BOS levels for retest detection
var float _bull_bos_level = na
var float _bear_bos_level = na
var int   _bull_bos_bar   = na
var int   _bear_bos_bar   = na
var float _bull_swing_low = na
var float _bear_swing_high= na

if _bull_bos
    _bull_bos_level  := _bull_target
    _bull_bos_bar    := bar_index
    _bull_swing_low  := _bull_swing_ref
    _bull_target     := na   // disarm — wait for next pivot

if _bear_bos
    _bear_bos_level  := _bear_target
    _bear_bos_bar    := bar_index
    _bear_swing_high := _bear_swing_ref
    _bear_target     := na

// Expire BOS levels after retest window
_bull_bos_valid = (not na(_bull_bos_level) and not na(_bull_bos_bar) and
                   (bar_index - _bull_bos_bar) <= i_retest_window)
_bear_bos_valid = (not na(_bear_bos_level) and not na(_bear_bos_bar) and
                   (bar_index - _bear_bos_bar) <= i_retest_window)

// ─────────────────────────────────────────────────────────────────────────────
// OTE ZONE (Fibonacci 61.8–78.6% retracement)
// After a bullish BOS, price retraces; entry in OTE zone = highest probability
// ─────────────────────────────────────────────────────────────────────────────
// Bullish OTE: from swing low (_bull_swing_low) to BOS high (_bull_bos_level)
float _ote_bull_entry_low  = na
float _ote_bull_entry_high = na

if _bull_bos_valid and not na(_bull_swing_low)
    float _range = _bull_bos_level - _bull_swing_low
    // Retracement: price pulls back FROM the high, OTE is 61.8-78.6% of the range
    _ote_bull_entry_low  := _bull_bos_level - i_ote_high * _range  // deeper retrace (78.6%)
    _ote_bull_entry_high := _bull_bos_level - i_ote_low  * _range  // shallower retrace (61.8%)

// Bearish OTE: from swing high to BOS low
float _ote_bear_entry_low  = na
float _ote_bear_entry_high = na

if _bear_bos_valid and not na(_bear_swing_high)
    float _range = _bear_swing_high - _bear_bos_level
    _ote_bear_entry_low  := _bear_bos_level + i_ote_low  * _range
    _ote_bear_entry_high := _bear_bos_level + i_ote_high * _range

// ─────────────────────────────────────────────────────────────────────────────
// RETEST DETECTION (entry signal)
// ─────────────────────────────────────────────────────────────────────────────
// Bullish retest: after BOS above, price comes back DOWN to the broken level
// and shows rejection (bullish candle body closes above the level)
_body_size   = math.abs(close - open)
_candle_range = high - low
_body_pct    = _candle_range > 0 ? _body_size / _candle_range : 0

// Volume gate
_vol_ok = volume > i_vol_mult * _vol_sma

// Bullish retest conditions:
// 1. Active BOS above
// 2. Low actually touched the BOS level (within 0.1 ATR above it)
// 3. Low didn't pierce more than tolerance below the level
// 4. Closed as bullish candle above the level (rejection)
// 5. Decent candle body
_bull_retest = _bull_bos_valid and
               low  <= _bull_bos_level + 0.1 * _atr and        // must touch level from above
               low  >= _bull_bos_level - i_retest_tol * _atr and // didn't pierce too deep
               close > open and
               close >= _bull_bos_level + 0.2 * _atr and   // close well above level (strong rejection)
               _body_pct >= 0.35 and
               _trend_bull and
               (not i_vol_filter or _vol_ok)

// OTE gate: if OTE filter on, close must also be in OTE zone
_bull_in_ote = not na(_ote_bull_entry_low) and not na(_ote_bull_entry_high) and
               close >= _ote_bull_entry_low and close <= _ote_bull_entry_high

_bull_entry = _bull_retest and
              (not i_ote_filter or _bull_in_ote) and
              (i_direction == "Both" or i_direction == "Long Only") and
              strategy.position_size == 0 and
              _ok_to_enter

// Bearish retest conditions (mirror of bullish):
_bear_retest = _bear_bos_valid and
               high >= _bear_bos_level - 0.1 * _atr and         // must touch level from below
               high <= _bear_bos_level + i_retest_tol * _atr and // didn't pierce too deep
               close < open and
               close < _bear_bos_level and
               _body_pct >= 0.35 and
               _trend_bear and
               (not i_vol_filter or _vol_ok)

_bear_in_ote = not na(_ote_bear_entry_low) and not na(_ote_bear_entry_high) and
               close >= _ote_bear_entry_low and close <= _ote_bear_entry_high

_bear_entry = _bear_retest and
              (not i_ote_filter or _bear_in_ote) and
              (i_direction == "Both" or i_direction == "Short Only") and
              strategy.position_size == 0 and
              _ok_to_enter

// DEBUG MODE: simple Heiken Ashi entry bypasses BOS/retest (for diagnostics)
// HA values
_ha_close = (open + high + low + close) / 4
var float _ha_open = na
_ha_open := na(_ha_open[1]) ? (open + close) / 2 : (_ha_open[1] + _ha_close[1]) / 2
_ha_bull  = _ha_close > _ha_open and _ha_close[1] <= _ha_open[1]   // HA reversal up
_ha_bear  = _ha_close < _ha_open and _ha_close[1] >= _ha_open[1]   // HA reversal down

_debug_bull = i_debug_ha and _ha_bull and close > _ema21 and close > _ema50 and
              strategy.position_size == 0 and _ok_to_enter and
              (i_direction == "Both" or i_direction == "Long Only")
_debug_bear = i_debug_ha and _ha_bear and close < _ema21 and close < _ema50 and
              strategy.position_size == 0 and _ok_to_enter and
              (i_direction == "Both" or i_direction == "Short Only")

// Final entry signals (BOS retest OR debug HA mode)
_final_bull = _bull_entry or _debug_bull
_final_bear = _bear_entry or _debug_bear

// ─────────────────────────────────────────────────────────────────────────────
// TRADE STATE TRACKING
// ─────────────────────────────────────────────────────────────────────────────
var float _entry_price   = na
var float _sl_price  = na
var float _tp_price  = na

// ─────────────────────────────────────────────────────────────────────────────
// ENTRIES — single exit at i_tp_r × SL distance
// ─────────────────────────────────────────────────────────────────────────────
if _final_bull
    float _sl_dist = i_sl_atr_mult * _atr
    float _sl      = close - _sl_dist
    float _tp      = close + i_tp_r * _sl_dist

    strategy.entry("Long", strategy.long, comment="AK Long")
    strategy.exit("L_Exit", "Long", limit=_tp, stop=_sl, comment="TP")

    _entry_price  := close
    _sl_price     := _sl
    _tp_price     := _tp
    _bull_bos_level := na

if _final_bear
    float _sl_dist = i_sl_atr_mult * _atr
    float _sl      = close + _sl_dist
    float _tp      = close - i_tp_r * _sl_dist

    strategy.entry("Short", strategy.short, comment="AK Short")
    strategy.exit("S_Exit", "Short", limit=_tp, stop=_sl, comment="TP")

    _entry_price  := close
    _sl_price     := _sl
    _tp_price     := _tp
    _bear_bos_level := na

// Reset state on position close
if strategy.position_size == 0 and not na(_entry_price)
    _entry_price  := na
    _sl_price     := na
    _tp_price     := na

// ─────────────────────────────────────────────────────────────────────────────
// VISUALS
// ─────────────────────────────────────────────────────────────────────────────

// EMA lines
plot(_ema21,  "EMA 21",  color=color.new(color.orange, 30),  linewidth=1)
plot(_ema50,  "EMA 50",  color=color.new(color.blue, 40),    linewidth=1)
plot(_ema200, "EMA 200", color=color.new(color.white, 50),   linewidth=2)

// BOS level lines (extend right from BOS bar)
if i_show_levels
    if _bull_bos
        line.new(bar_index, _last_ph, bar_index + 40, _last_ph,
             color=color.new(color.lime, 30), width=1, style=line.style_dashed,
             extend=extend.none)
    if _bear_bos
        line.new(bar_index, _last_pl, bar_index + 40, _last_pl,
             color=color.new(color.red, 30), width=1, style=line.style_dashed,
             extend=extend.none)

// BOS labels
if i_show_bos
    if _bull_bos
        label.new(bar_index, high + _atr * 0.3, "BOS↑",
             color=color.new(color.lime, 20), textcolor=color.white,
             style=label.style_label_down, size=size.small)
    if _bear_bos
        label.new(bar_index, low - _atr * 0.3, "BOS↓",
             color=color.new(color.red, 20), textcolor=color.white,
             style=label.style_label_up, size=size.small)

// Entry signals
if i_show_retest
    if _bull_entry
        label.new(bar_index, low - _atr * 0.4,
             "AK LONG\n" + str.tostring(close, "#.##") + "\nSL " + str.tostring(_sl_price, "#.##"),
             color=color.new(color.aqua, 15), textcolor=color.white,
             style=label.style_label_up, size=size.normal)
    if _bear_entry
        label.new(bar_index, high + _atr * 0.4,
             "AK SHORT\n" + str.tostring(close, "#.##") + "\nSL " + str.tostring(_sl_price, "#.##"),
             color=color.new(color.red, 15), textcolor=color.white,
             style=label.style_label_down, size=size.normal)

// TP/SL lines for open trade
if strategy.position_size != 0 and not na(_sl_price)
    line.new(bar_index - 1, _sl_price, bar_index + 1, _sl_price,
         color=color.new(color.red, 0), width=2, extend=extend.right)
    if not na(_tp_price)
        line.new(bar_index - 1, _tp_price, bar_index + 1, _tp_price,
             color=color.new(color.lime, 20), width=2, extend=extend.right)

// Session background (London–NY overlap)
bgcolor(_in_session ? color.new(color.blue, 96) : na, title="London–NY Session")

// Friday cutoff warning
bgcolor(_is_friday and hour >= 15 and minute >= 30 ? color.new(color.red, 94) : na,
     title="Friday Cutoff")

// ─────────────────────────────────────────────────────────────────────────────
// INFO TABLE
// ─────────────────────────────────────────────────────────────────────────────
if i_show_table and barstate.islast
    var table t = table.new(position.top_right, 2, 12,
         bgcolor=color.new(color.black, 70), border_color=color.gray, border_width=1)

    table.cell(t, 0, 0, "ALPHA KILL v1",   text_color=color.yellow, text_size=size.small,
         bgcolor=color.new(color.navy, 40))
    table.cell(t, 1, 0, syminfo.ticker,    text_color=color.yellow, text_size=size.small,
         bgcolor=color.new(color.navy, 40))

    table.cell(t, 0, 1, "D1 Trend",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 1, _d1_bull ? "▲ BULL" : _d1_bear ? "▼ BEAR" : "—",
         text_color=_d1_bull ? color.lime : _d1_bear ? color.red : color.gray,
         text_size=size.tiny)

    table.cell(t, 0, 2, "H4 Trend",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 2, _h4_bull ? "▲ BULL" : _h4_bear ? "▼ BEAR" : "—",
         text_color=_h4_bull ? color.lime : _h4_bear ? color.red : color.gray,
         text_size=size.tiny)

    table.cell(t, 0, 3, "Session",   text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 3, _in_session ? "ACTIVE" : "—",
         text_color=_in_session ? color.aqua : color.gray, text_size=size.tiny)

    table.cell(t, 0, 4, "Bull BOS",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 4, _bull_bos_valid ? str.tostring(_bull_bos_level, "#.##") : "—",
         text_color=_bull_bos_valid ? color.lime : color.gray, text_size=size.tiny)

    table.cell(t, 0, 5, "Bear BOS",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 5, _bear_bos_valid ? str.tostring(_bear_bos_level, "#.##") : "—",
         text_color=_bear_bos_valid ? color.red : color.gray, text_size=size.tiny)

    table.cell(t, 0, 6, "ATR(14)",   text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 6, str.tostring(_atr, "#.####"), text_color=color.white, text_size=size.tiny)

    table.cell(t, 0, 7, "Volume",    text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 7, volume > i_vol_mult * _vol_sma ? "SPIKE ✓" : "Normal",
         text_color=volume > i_vol_mult * _vol_sma ? color.lime : color.gray, text_size=size.tiny)

    table.cell(t, 0, 8, "Position",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 8, strategy.position_size > 0 ? "LONG" :
                         strategy.position_size < 0 ? "SHORT" : "FLAT",
         text_color=strategy.position_size > 0 ? color.lime :
                    strategy.position_size < 0 ? color.red : color.gray,
         text_size=size.tiny)

    table.cell(t, 0, 9, "TP",        text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 9, not na(_tp_price) ? str.tostring(_tp_price, "#.##") : "—",
         text_color=not na(_tp_price) ? color.lime : color.gray, text_size=size.tiny)

    table.cell(t, 0, 10, "Open P&L", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 10, str.tostring(strategy.openprofit, "#.##"),
         text_color=strategy.openprofit >= 0 ? color.lime : color.red, text_size=size.tiny)

    table.cell(t, 0, 11, "Net P&L",  text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 11, str.tostring(strategy.netprofit, "#.##"),
         text_color=strategy.netprofit >= 0 ? color.lime : color.red, text_size=size.tiny)
