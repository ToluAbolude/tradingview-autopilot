// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  AUTO TRENDLINES — ZONE & BREAK  (indicator, not a strategy)               ║
// ║                                                                           ║
// ║  Draws support / resistance trendlines the way the playbook describes:     ║
// ║  (TRADING_KNOWLEDGE_BASE.md §"Trendline Methodology" + tori_trades_*.pine) ║
// ║                                                                           ║
// ║  DRAWING RULES                                                             ║
// ║   • Resistance TL = connects LOWER HIGHS  (downward slope)                 ║
// ║   • Support   TL = connects HIGHER LOWS   (upward slope)                   ║
// ║   • Connect the MAXIMUM number of touches (best-fit over ALL pivot pairs)  ║
// ║   • A valid line must CONTAIN price: no high pokes above a resistance line, ║
// ║     no low pokes below a support line (beyond the touch tolerance)         ║
// ║   • 3+ touches = tradeable.  1 touch = accident, 2 = coincidence.          ║
// ║                                                                           ║
// ║  TRENDLINES ARE ZONES, NOT LINES                                          ║
// ║   • Each line is wrapped in an ATR-scaled zone band.                       ║
// ║   • Wick poke THROUGH the zone = liquidity grab → NOT a break (orange ✕).  ║
// ║   • Only a BODY CLOSE beyond the zone confirms a break (BRK ▲ / ▼).        ║
// ║   • Rejection back out of the zone = bounce signal.                        ║
// ╚═══════════════════════════════════════════════════════════════════════════╝
//@version=6
indicator("Auto Trendlines — Zone & Break", shorttitle="AutoTL", overlay=true, max_lines_count=20, max_labels_count=20)

// ─────────────────────────────────────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────────────────────────────────────
var string GD = "① Detection"
i_plen     = input.int  (5,   "Pivot Lookback (bars each side)", minval=2, maxval=50,  group=GD, tooltip="Larger = more significant swings, fewer lines. 5 ≈ standard swings.")
i_mintouch = input.int  (3,   "Min Touches (3 = tradeable)",    minval=2, maxval=8,   group=GD, tooltip="Playbook: 1 touch=accident, 2=coincidence, 3+=tradeable.")
i_minbars  = input.int  (20,  "Min Bars Spanned",               minval=5, maxval=500, group=GD, tooltip="Reject lines too short to be a real trend.")
i_maxpiv   = input.int  (10,  "Pivots Kept Per Side",           minval=4, maxval=20,  group=GD, tooltip="How many recent swing highs/lows to fit through.")
i_classic  = input.bool (true,"Classic slope only",             group=GD, tooltip="ON: resistance must slope down (lower highs), support up (higher lows). OFF: also allow channel lines.")
i_maxdist  = input.float(12.0,"Max Distance From Price (×ATR)", minval=2, maxval=50, step=0.5, group=GD, tooltip="Ignore lines projecting far from current price (not actionable).")

var string GZ = "② Zone (trendlines are zones, not lines)"
i_touchtol = input.float(0.5, "Touch Tolerance (×ATR14)",       minval=0.05, maxval=2.0, step=0.05, group=GZ, tooltip="How close a pivot must be to count as a touch.")
i_zone     = input.float(0.25,"Zone Half-Width (×ATR14)",       minval=0.0,  maxval=2.0, step=0.05, group=GZ, tooltip="Visual band around the line. Body must close beyond the band to confirm a break.")

var string GS = "③ Signals"
i_showbreak  = input.bool(true, "Confirmed Breaks (body close)",  group=GS)
i_showpoke   = input.bool(true, "Wick Pokes (liquidity grabs)",   group=GS)
i_showbounce = input.bool(true, "Zone Bounces (rejections)",      group=GS)

var string GV = "④ Display"
i_showres   = input.bool(true, "Show Resistance Trendline", group=GV)
i_showsup   = input.bool(true, "Show Support Trendline",    group=GV)
i_showzone  = input.bool(true, "Show Zone Band",            group=GV)
i_showlabel = input.bool(true, "Show Touch-Count Labels",   group=GV)
i_showtable = input.bool(true, "Show Status Table",         group=GV)
i_extend    = input.int (20,   "Extend Lines (bars right)", minval=0, maxval=200, group=GV)

// ─────────────────────────────────────────────────────────────────────────────
// COLORS
// ─────────────────────────────────────────────────────────────────────────────
C_RES    = #f23645
C_SUP    = #089981
C_BRK_UP = #00e676
C_BRK_DN = #ff1744
C_POKE   = #ff9800

// ─────────────────────────────────────────────────────────────────────────────
// CORE
// ─────────────────────────────────────────────────────────────────────────────
_atr     = ta.atr(14)
tol      = i_touchtol * _atr
halfZone = i_zone * _atr

// Price of a line through (x1,y1)-(x2,y2) at bar x
lineAt(int x1, float y1, int x2, float y2, int x) =>
    x1 == x2 ? y1 : y1 + (y2 - y1) / float(x2 - x1) * float(x - x1)

// ── Pivot storage ────────────────────────────────────────────────────────────
_ph = ta.pivothigh(high, i_plen, i_plen)
_pl = ta.pivotlow (low,  i_plen, i_plen)

var int[]   phx = array.new_int()
var float[] phy = array.new_float()
var int[]   plx = array.new_int()
var float[] ply = array.new_float()

if not na(_ph)
    array.push(phx, bar_index - i_plen)
    array.push(phy, _ph)
    if array.size(phx) > i_maxpiv
        array.shift(phx)
        array.shift(phy)

if not na(_pl)
    array.push(plx, bar_index - i_plen)
    array.push(ply, _pl)
    if array.size(plx) > i_maxpiv
        array.shift(plx)
        array.shift(ply)

// ─────────────────────────────────────────────────────────────────────────────
// BEST-FIT TRENDLINE
// Search ALL pivot pairs; keep the line with the most touches that also
// CONTAINS price (no pivot of that kind pierces beyond the tolerance).
// ─────────────────────────────────────────────────────────────────────────────
findRes() =>
    int n = array.size(phx)
    bool  found = false
    int   bx1 = 0
    float by1 = 0.0
    int   bx2 = 0
    float by2 = 0.0
    int   bestTouch = 0
    int   bestSpan  = 0
    if n >= 2
        for a = 0 to n - 2
            for b = a + 1 to n - 1
                int   x1   = array.get(phx, a)
                float y1   = array.get(phy, a)
                int   x2   = array.get(phx, b)
                float y2   = array.get(phy, b)
                int   span = x2 - x1
                float slope = span == 0 ? 0.0 : (y2 - y1) / span
                bool ok = span >= i_minbars and not (i_classic and slope > 0)
                if ok
                    int  touches   = 0
                    bool contained = true
                    for k = 0 to n - 1
                        float py   = array.get(phy, k)
                        float lv   = lineAt(x1, y1, x2, y2, array.get(phx, k))
                        float diff = py - lv            // + = pivot above the line
                        if diff > tol
                            contained := false
                        if math.abs(diff) <= tol
                            touches += 1
                    float projNow = lineAt(x1, y1, x2, y2, bar_index)
                    bool relevant = math.abs(projNow - close) <= i_maxdist * _atr
                    if contained and relevant and touches >= i_mintouch and (touches > bestTouch or (touches == bestTouch and span > bestSpan))
                        found     := true
                        bx1       := x1
                        by1       := y1
                        bx2       := x2
                        by2       := y2
                        bestTouch := touches
                        bestSpan  := span
    [found, bx1, by1, bx2, by2, bestTouch]

findSup() =>
    int n = array.size(plx)
    bool  found = false
    int   bx1 = 0
    float by1 = 0.0
    int   bx2 = 0
    float by2 = 0.0
    int   bestTouch = 0
    int   bestSpan  = 0
    if n >= 2
        for a = 0 to n - 2
            for b = a + 1 to n - 1
                int   x1   = array.get(plx, a)
                float y1   = array.get(ply, a)
                int   x2   = array.get(plx, b)
                float y2   = array.get(ply, b)
                int   span = x2 - x1
                float slope = span == 0 ? 0.0 : (y2 - y1) / span
                bool ok = span >= i_minbars and not (i_classic and slope < 0)
                if ok
                    int  touches   = 0
                    bool contained = true
                    for k = 0 to n - 1
                        float py   = array.get(ply, k)
                        float lv   = lineAt(x1, y1, x2, y2, array.get(plx, k))
                        float diff = py - lv            // − = pivot below the line
                        if diff < -tol
                            contained := false
                        if math.abs(diff) <= tol
                            touches += 1
                    float projNow = lineAt(x1, y1, x2, y2, bar_index)
                    bool relevant = math.abs(projNow - close) <= i_maxdist * _atr
                    if contained and relevant and touches >= i_mintouch and (touches > bestTouch or (touches == bestTouch and span > bestSpan))
                        found     := true
                        bx1       := x1
                        by1       := y1
                        bx2       := x2
                        by2       := y2
                        bestTouch := touches
                        bestSpan  := span
    [found, bx1, by1, bx2, by2, bestTouch]

[rf, rx1, ry1, rx2, ry2, rtouch] = findRes()
[sf, sx1, sy1, sx2, sy2, stouch] = findSup()

resLine = rf ? lineAt(rx1, ry1, rx2, ry2, bar_index) : na
supLine = sf ? lineAt(sx1, sy1, sx2, sy2, bar_index) : na
resTop  = resLine + halfZone
resBot  = resLine - halfZone
supTop  = supLine + halfZone
supBot  = supLine - halfZone

// ─────────────────────────────────────────────────────────────────────────────
// STABILITY GUARD — only call a break when the line did not just re-fit this bar
// (prevents false breaks from the detector swapping to a different pivot pair).
// ─────────────────────────────────────────────────────────────────────────────
var int prevRx1 = 0
var int prevRx2 = 0
var int prevSx1 = 0
var int prevSx2 = 0
resStable = rf and rx1 == prevRx1 and rx2 == prevRx2
supStable = sf and sx1 == prevSx1 and sx2 == prevSx2
prevRx1 := rf ? rx1 : prevRx1
prevRx2 := rf ? rx2 : prevRx2
prevSx1 := sf ? sx1 : prevSx1
prevSx2 := sf ? sx2 : prevSx2

// ─────────────────────────────────────────────────────────────────────────────
// EVENTS  (break = body close beyond zone; poke = wick only; bounce = rejection)
// ─────────────────────────────────────────────────────────────────────────────
// Evaluate crossovers every bar (never behind `and`) so their history stays consistent.
_resCross   = ta.crossover (close, resTop)
_supCross   = ta.crossunder(close, supBot)
breakUp     = resStable and _resCross
breakDn     = supStable and _supCross
pokeUp      = rf and high > resTop and close <= resTop
pokeDn      = sf and low  < supBot and close >= supBot
bounceShort = rf and high >= resBot and close < resBot and close < open
bounceLong  = sf and low  <= supTop and close > supTop and close > open

// ─────────────────────────────────────────────────────────────────────────────
// VISUALS — lines + zone bands + labels (redrawn on the last bar)
// ─────────────────────────────────────────────────────────────────────────────
var line     resMid = na
var line     resHi  = na
var line     resLo  = na
var line     supMid = na
var line     supHi  = na
var line     supLo  = na
var linefill resFill = na
var linefill supFill = na
var label    resLbl  = na
var label    supLbl  = na

if barstate.islast
    line.delete(resMid)
    line.delete(resHi)
    line.delete(resLo)
    line.delete(supMid)
    line.delete(supHi)
    line.delete(supLo)
    linefill.delete(resFill)
    linefill.delete(supFill)
    label.delete(resLbl)
    label.delete(supLbl)
    int ext = bar_index + i_extend

    if i_showres and rf
        float ry_end = lineAt(rx1, ry1, rx2, ry2, ext)
        resMid := line.new(rx1, ry1, ext, ry_end, color=color.new(C_RES, 0), width=2)
        if i_showzone and halfZone > 0
            resHi  := line.new(rx1, ry1 + halfZone, ext, ry_end + halfZone, color=color.new(C_RES, 70), width=1)
            resLo  := line.new(rx1, ry1 - halfZone, ext, ry_end - halfZone, color=color.new(C_RES, 70), width=1)
            resFill := linefill.new(resHi, resLo, color=color.new(C_RES, 90))
        if i_showlabel
            resLbl := label.new(ext, ry_end, "RES  ▼ ×" + str.tostring(rtouch),
                 style=label.style_label_left, color=color.new(C_RES, 15), textcolor=color.white, size=size.small)

    if i_showsup and sf
        float sy_end = lineAt(sx1, sy1, sx2, sy2, ext)
        supMid := line.new(sx1, sy1, ext, sy_end, color=color.new(C_SUP, 0), width=2)
        if i_showzone and halfZone > 0
            supHi  := line.new(sx1, sy1 + halfZone, ext, sy_end + halfZone, color=color.new(C_SUP, 70), width=1)
            supLo  := line.new(sx1, sy1 - halfZone, ext, sy_end - halfZone, color=color.new(C_SUP, 70), width=1)
            supFill := linefill.new(supHi, supLo, color=color.new(C_SUP, 90))
        if i_showlabel
            supLbl := label.new(ext, sy_end, "SUP  ▲ ×" + str.tostring(stouch),
                 style=label.style_label_left, color=color.new(C_SUP, 15), textcolor=color.white, size=size.small)

// Faint live line value (so the projected level is visible bar-to-bar too)
plot(resLine, "Resistance value", color=color.new(C_RES, 55), linewidth=1, style=plot.style_linebr)
plot(supLine, "Support value",    color=color.new(C_SUP, 55), linewidth=1, style=plot.style_linebr)

// ── Event markers ────────────────────────────────────────────────────────────
plotshape(i_showbreak  and breakUp,     "Break Up",      shape.triangleup,   location.belowbar, color.new(C_BRK_UP, 0), size=size.small, text="BRK")
plotshape(i_showbreak  and breakDn,     "Break Down",    shape.triangledown, location.abovebar, color.new(C_BRK_DN, 0), size=size.small, text="BRK")
plotshape(i_showpoke   and pokeUp,      "Poke Up",       shape.xcross,       location.abovebar, color.new(C_POKE, 0),   size=size.tiny)
plotshape(i_showpoke   and pokeDn,      "Poke Down",     shape.xcross,       location.belowbar, color.new(C_POKE, 0),   size=size.tiny)
plotshape(i_showbounce and bounceLong,  "Bounce Long",   shape.triangleup,   location.belowbar, color.new(C_SUP, 20),   size=size.tiny)
plotshape(i_showbounce and bounceShort, "Bounce Short",  shape.triangledown, location.abovebar, color.new(C_RES, 20),   size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────────────────────────────────────
alertcondition(breakUp,     "Resistance Break",  "AutoTL: body close ABOVE resistance trendline zone (confirmed break)")
alertcondition(breakDn,     "Support Break",     "AutoTL: body close BELOW support trendline zone (confirmed break)")
alertcondition(bounceLong,  "Support Bounce",    "AutoTL: bullish rejection at support trendline zone")
alertcondition(bounceShort, "Resistance Bounce", "AutoTL: bearish rejection at resistance trendline zone")
alertcondition(pokeUp or pokeDn, "Liquidity Grab", "AutoTL: wick poked through the trendline zone but did not close beyond it")

// ─────────────────────────────────────────────────────────────────────────────
// STATUS TABLE
// ─────────────────────────────────────────────────────────────────────────────
var table tb = table.new(position.top_right, 2, 4, bgcolor=color.new(#0d0d1a, 30), border_width=1, border_color=color.new(color.gray, 70))

if barstate.islast and i_showtable
    table.cell(tb, 0, 0, "AUTO TRENDLINES", text_color=color.white, text_size=size.small, bgcolor=color.new(#1a1a2e, 0))
    table.cell(tb, 1, 0, str.tostring(i_mintouch) + "+ touch", text_color=color.silver, text_size=size.small, bgcolor=color.new(#1a1a2e, 0))

    string rtxt = rf ? "▼ " + str.tostring(rtouch) + "tch  @ " + str.tostring(resLine, format.mintick) : "— none"
    table.cell(tb, 0, 1, "Resistance", text_color=color.new(C_RES, 0), text_size=size.small)
    table.cell(tb, 1, 1, rtxt, text_color=color.white, text_size=size.small)

    string stxt = sf ? "▲ " + str.tostring(stouch) + "tch  @ " + str.tostring(supLine, format.mintick) : "— none"
    table.cell(tb, 0, 2, "Support", text_color=color.new(C_SUP, 0), text_size=size.small)
    table.cell(tb, 1, 2, stxt, text_color=color.white, text_size=size.small)

    string evt = breakUp ? "BREAK ▲" : breakDn ? "BREAK ▼" : bounceLong ? "Bounce ▲" : bounceShort ? "Bounce ▼" : (pokeUp or pokeDn) ? "Wick poke (grab)" : "—"
    color  evc = breakUp or bounceLong ? C_BRK_UP : breakDn or bounceShort ? C_BRK_DN : (pokeUp or pokeDn) ? C_POKE : color.gray
    table.cell(tb, 0, 3, "Last event", text_color=color.silver, text_size=size.small)
    table.cell(tb, 1, 3, evt, text_color=evc, text_size=size.small)
