//@version=6
strategy("Riley Coleman S&R Reversal", overlay = true,
     initial_capital     = 100000,
     default_qty_type    = strategy.fixed,
     default_qty_value   = 1,
     commission_type     = strategy.commission.cash_per_contract,
     commission_value    = 2.0,
     slippage            = 1,
     margin_long         = 100,
     margin_short        = 100)

// ─────────────────────────────────────────────
//  INPUT GROUPS
// ─────────────────────────────────────────────
var string G_SESSION = "Session"
var string G_ZONE    = "S&R Zone Settings"
var string G_EXHAUST = "Exhaustive Move Filter"
var string G_RISK    = "Risk Management"
var string G_BACK    = "Backtest Period"

// Session
sessionInput   = input.session("0930-1130:23456", "Trading Window (EST)",  group = G_SESSION)
tzInput        = input.string("America/New_York",  "Timezone",              group = G_SESSION)
htfInput       = input.timeframe("15",             "HTF for S&R Zones",    group = G_SESSION)

// Zone
pivotLen       = input.int(5,   "Pivot Length (HTF)",         minval = 2,  group = G_ZONE)
zoneProx       = input.float(0.15, "Zone Width (%)",          step = 0.01, group = G_ZONE) / 100
minTouches     = input.int(2,   "Min Zone Touches (strength)", minval = 1, maxval = 5, group = G_ZONE, tooltip = "Require at least N touches before trading a zone")
zoneLookback   = input.int(80,  "Zone Lookback (bars)",        minval = 20, group = G_ZONE)

// Exhaustive move
volMult        = input.float(1.5, "Volume Spike Multiplier",   step = 0.1, group = G_EXHAUST)
bodyThresh     = input.float(0.6, "3-Bar Body Avg Threshold",  step = 0.1, group = G_EXHAUST)
atrMult        = input.float(1.2, "3-Bar Range vs ATR",        step = 0.1, group = G_EXHAUST)

// Risk
rrRatio        = input.float(3.0, "Risk:Reward Ratio",         step = 0.5, group = G_RISK)
beTrigger      = input.float(1.0, "Break-Even Trigger (R)",    step = 0.1, group = G_RISK, tooltip = "Move SL to break-even after this many R in profit")
trailR         = input.float(2.0, "Trailing Stop Activate (R)",step = 0.1, group = G_RISK, tooltip = "Activate trailing stop after this many R in profit")
slBuffer       = input.int(2,     "SL Buffer (ticks)",                     group = G_RISK)

// Backtest
startDate      = input.time(timestamp("2024-01-01 00:00"), "Start Date", group = G_BACK)
endDate        = input.time(timestamp("2026-12-31 23:59"), "End Date",   group = G_BACK)

// ─────────────────────────────────────────────
//  COLORS
// ─────────────────────────────────────────────
C_BULL = #089981
C_BEAR = #f23645
C_ZONE = color.new(color.orange, 85)

// ─────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────
in_session() => not na(time(timeframe.period, sessionInput, tzInput))
in_range()   => time >= startDate and time <= endDate

body_ratio(o, h, l, c) =>
    rng = h - l
    rng == 0 ? 0.0 : math.abs(c - o) / rng

// ─────────────────────────────────────────────
//  HTF S&R ZONE DETECTION  (15m pivots)
//  Riley rule: zones need ≥ 2 touches to be "strong"
// ─────────────────────────────────────────────
[htf_ph, htf_pl] = request.security(syminfo.tickerid, htfInput,
     [ta.pivothigh(pivotLen, pivotLen), ta.pivotlow(pivotLen, pivotLen)],
     lookahead = barmerge.lookahead_off)

// Store pivot arrays
var float[] res_levels  = array.new_float()
var int[]   res_touches = array.new_int()
var float[] sup_levels  = array.new_float()
var int[]   sup_touches = array.new_int()

// Add new pivots (deduplicate)
if not na(htf_ph)
    isDupe = false
    if array.size(res_levels) > 0
        for i = 0 to array.size(res_levels) - 1
            if math.abs(htf_ph - array.get(res_levels, i)) <= htf_ph * zoneProx
                array.set(res_touches, i, array.get(res_touches, i) + 1)
                isDupe := true
                break
    if not isDupe
        array.push(res_levels,  htf_ph)
        array.push(res_touches, 1)
        if array.size(res_levels) > zoneLookback
            array.shift(res_levels)
            array.shift(res_touches)

if not na(htf_pl)
    isDupe = false
    if array.size(sup_levels) > 0
        for i = 0 to array.size(sup_levels) - 1
            if math.abs(htf_pl - array.get(sup_levels, i)) <= htf_pl * zoneProx
                array.set(sup_touches, i, array.get(sup_touches, i) + 1)
                isDupe := true
                break
    if not isDupe
        array.push(sup_levels,  htf_pl)
        array.push(sup_touches, 1)
        if array.size(sup_levels) > zoneLookback
            array.shift(sup_levels)
            array.shift(sup_touches)

// Find nearest strong S&R zones (≥ minTouches)
float activeRes = na  // R1 — resistance above price
float activeSup = na  // S1 — support below price

if array.size(res_levels) > 0
    float bestRes = na
    for i = 0 to array.size(res_levels) - 1
        lvl     = array.get(res_levels, i)
        touches = array.get(res_touches, i)
        if touches >= minTouches and lvl > close
            if na(bestRes) or lvl < bestRes
                bestRes := lvl
    activeRes := bestRes

if array.size(sup_levels) > 0
    float bestSup = na
    for i = 0 to array.size(sup_levels) - 1
        lvl     = array.get(sup_levels, i)
        touches = array.get(sup_touches, i)
        if touches >= minTouches and lvl < close
            if na(bestSup) or lvl > bestSup
                bestSup := lvl
    activeSup := bestSup

// Zone width for "zone thinking" (not lines)
resZoneHigh = not na(activeRes) ? activeRes * (1 + zoneProx) : na
resZoneLow  = not na(activeRes) ? activeRes * (1 - zoneProx) : na
supZoneHigh = not na(activeSup) ? activeSup * (1 + zoneProx) : na
supZoneLow  = not na(activeSup) ? activeSup * (1 - zoneProx) : na

// Price at extremes check
atResistance = not na(activeRes) and close >= resZoneLow and close <= resZoneHigh * 1.005
atSupport    = not na(activeSup) and close >= supZoneLow  * 0.995 and close <= supZoneHigh

// Flip zones: broken sup becomes res, broken res becomes sup
var float flipRes = na
var float flipSup = na
if not na(activeSup) and close < activeSup * (1 - zoneProx)  // broke below support
    flipRes := activeSup   // that support is now resistance
if not na(activeRes) and close > activeRes * (1 + zoneProx)  // broke above resistance
    flipSup := activeRes   // that resistance is now support

// ─────────────────────────────────────────────
//  EXHAUSTIVE / "UNHEALTHY" MOVE DETECTION
//  (Riley: fast move into zone = prime reversal)
// ─────────────────────────────────────────────
atr    = ta.atr(14)
avgVol = ta.sma(volume, 20)

bar0Body = body_ratio(open,    high,    low,    close)
bar1Body = body_ratio(open[1], high[1], low[1], close[1])
bar2Body = body_ratio(open[2], high[2], low[2], close[2])
threeBarBodyAvg = (bar0Body + bar1Body + bar2Body) / 3
threeBarRange   = math.max(high, high[1], high[2]) - math.min(low, low[1], low[2])

exhaustiveMove = threeBarBodyAvg > bodyThresh and
                 threeBarRange   > atr * atrMult and
                 volume          > avgVol * volMult

// ─────────────────────────────────────────────
//  TRENDLINE BREAK / MARKET STRUCTURE SHIFT
//  "1-Minute Shift" — lower highs broken for longs,
//                     higher lows broken for shorts
// ─────────────────────────────────────────────
swingHigh = ta.pivothigh(3, 3)
swingLow  = ta.pivotlow(3, 3)

var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(swingHigh)
    lastSwingHigh := swingHigh
if not na(swingLow)
    lastSwingLow := swingLow

// Trendline break = price closes beyond last swing
bullTrendBreak = not na(lastSwingHigh) and close > lastSwingHigh  // breaks downtrend trendline
bearTrendBreak = not na(lastSwingLow)  and close < lastSwingLow   // breaks uptrend trendline

// ─────────────────────────────────────────────
//  ENTRY PATTERN (Candle Confirmation)
// ─────────────────────────────────────────────
isEngulfing = math.abs(close - open) > math.abs(close[1] - open[1]) and
              (close > open) != (close[1] > open[1])

isMarubozu  = bar0Body > 0.8 and
              (close < open ?
               close <= low  + (high - low) * 0.25 :
               close >= high - (high - low) * 0.25)

entryPattern = isEngulfing or isMarubozu

// ─────────────────────────────────────────────
//  FAILED BREAKOUT TRAP FILTER
//  (Riley: avoid "barely broke previous high then reversed")
//  Skip signal if we just barely broke a zone by < 0.05%
// ─────────────────────────────────────────────
bareTrapLong  = not na(activeRes) and high > activeRes and (high - activeRes) < activeRes * 0.0005 and close < activeRes
bareTrapShort = not na(activeSup) and low  < activeSup and (activeSup - low)  < activeSup * 0.0005 and close > activeSup
notATrap = not bareTrapLong and not bareTrapShort

// ─────────────────────────────────────────────
//  FINAL ENTRY CONDITIONS
// ─────────────────────────────────────────────
inSess  = in_session()
inRange = in_range()

longCondition  = inRange and inSess and
                 atSupport       and   // price at strong HTF S1 zone
                 exhaustiveMove  and   // overextended move into zone
                 bullTrendBreak  and   // 1-min shift / trendline break up
                 entryPattern    and   // engulfing or marubozu candle
                 notATrap              // not a trap breakout

shortCondition = inRange and inSess and
                 atResistance    and   // price at strong HTF R1 zone
                 exhaustiveMove  and   // overextended move into zone
                 bearTrendBreak  and   // 1-min shift / trendline break down
                 entryPattern    and   // engulfing or marubozu candle
                 notATrap              // not a trap breakout

// ─────────────────────────────────────────────
//  STRATEGY EXECUTION
// ─────────────────────────────────────────────
var float entryPx  = na
var float stopPx   = na
var float targetPx = na
var bool  beDone   = false
var bool  trailOn  = false
var float trailStop = na

if longCondition and strategy.position_size == 0
    entryPx  := close
    stopPx   := math.min(low, low[1]) - slBuffer * syminfo.mintick
    risk      = entryPx - stopPx
    targetPx := entryPx + risk * rrRatio
    beDone   := false
    trailOn  := false
    trailStop := na
    strategy.entry("Long", strategy.long, comment = "L: Zone+Break+Pattern")

if shortCondition and strategy.position_size == 0
    entryPx  := close
    stopPx   := math.max(high, high[1]) + slBuffer * syminfo.mintick
    risk      = stopPx - entryPx
    targetPx := entryPx - risk * rrRatio
    beDone   := false
    trailOn  := false
    trailStop := na
    strategy.entry("Short", strategy.short, comment = "S: Zone+Break+Pattern")

// Manage open long
if strategy.position_size > 0
    risk = entryPx - stopPx
    // Break-even
    if not beDone and high >= entryPx + risk * beTrigger
        stopPx := entryPx + syminfo.mintick
        beDone := true
    // Trailing stop activation
    if high >= entryPx + risk * trailR
        trailOn := true
    if trailOn
        trailStop := na(trailStop) ? high - risk : math.max(trailStop, high - risk)
        stopPx    := math.max(stopPx, trailStop)
    strategy.exit("Exit L", limit = targetPx, stop = stopPx, comment_profit = "TP", comment_loss = "SL")

// Manage open short
if strategy.position_size < 0
    risk = stopPx - entryPx
    // Break-even
    if not beDone and low <= entryPx - risk * beTrigger
        stopPx := entryPx - syminfo.mintick
        beDone := true
    // Trailing stop activation
    if low <= entryPx - risk * trailR
        trailOn := true
    if trailOn
        trailStop := na(trailStop) ? low + risk : math.min(trailStop, low + risk)
        stopPx    := math.min(stopPx, trailStop)
    strategy.exit("Exit S", limit = targetPx, stop = stopPx, comment_profit = "TP", comment_loss = "SL")

// ─────────────────────────────────────────────
//  VISUALS
// ─────────────────────────────────────────────
// HTF S&R Zones (as bands, not lines — "think in zones")
plot(activeRes, "Resistance (R1)", color.new(C_BEAR, 30), 2, plot.style_linebr)
plot(resZoneLow, "Res Zone Low",   color.new(C_BEAR, 80), 1, plot.style_linebr)
plot(activeSup,  "Support (S1)",   color.new(C_BULL, 30), 2, plot.style_linebr)
plot(supZoneHigh,"Sup Zone High",  color.new(C_BULL, 80), 1, plot.style_linebr)

// Entry signals
plotshape(longCondition,  "BUY",  shape.labelup,   location.belowbar, C_BULL, size = size.normal, text = "BUY",  textcolor = color.white)
plotshape(shortCondition, "SELL", shape.labeldown,  location.abovebar, C_BEAR, size = size.normal, text = "SELL", textcolor = color.white)

// Exhaustive move marker (small triangle)
plotshape(exhaustiveMove and inSess, "Exhaust", shape.triangleup, location.bottom, color.new(color.yellow, 40), size = size.tiny)

// Zone highlight when price is at extremes
bgcolor(atSupport    ? color.new(C_BULL, 90) : na, title = "At Support Zone")
bgcolor(atResistance ? color.new(C_BEAR, 90) : na, title = "At Resistance Zone")

// Session background
bgcolor(inSess ? color.new(color.blue, 96) : na, title = "Trading Session")

// ─────────────────────────────────────────────
//  ALERTS
// ─────────────────────────────────────────────
alertcondition(longCondition,  "BUY Signal",  "Riley Coleman S&R — BUY: All 5 checklist items met at Support Zone")
alertcondition(shortCondition, "SELL Signal", "Riley Coleman S&R — SELL: All 5 checklist items met at Resistance Zone")
